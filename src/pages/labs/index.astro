---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const labs = (await getCollection("labs")).sort((a, b) => {
  const orderA = a.data.order ?? 999;
  const orderB = b.data.order ?? 999;
  return orderA - orderB;
});

const difficultyStyles: Record<string, string> = {
  easy: "background: #ecfdf5; color: #047857; border: 1px solid #a7f3d0;",
  medium: "background: #fffbeb; color: #b45309; border: 1px solid #fde68a;",
  hard: "background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca;",
};

const difficultyLabel: Record<string, string> = {
  easy: "Easy",
  medium: "Medium",
  hard: "Hard",
};
---

<Base title="Labs" description="Claude Labs. Hands-on, guided sessions that produce real artifacts you can use in your actual work.">
  <div class="page">
    <header class="lab-hero">
      <p class="eyebrow">CLAUDE LABS</p>
      <h1>Learn by doing.</h1>
      <p class="lead">
        Each lab is a guided, hands-on session that produces a real artifact you can use in your actual work. Pick one up, follow the checkpoints, and walk away with something you can ship tomorrow.
      </p>
    </header>

    <section class="banner">
      <div class="banner-inner">
        <div>
          <p class="eyebrow eyebrow-light">HOW LABS WORK</p>
          <h2>Inspired. Capable. Compounding.</h2>
          <p>Labs pair a working example with a guided build. You leave with an artifact in your hands, and every lab you complete makes the next one faster.</p>
        </div>
        <ol class="steps">
          <li><span>01</span><div><strong>Pick a lab.</strong> Match it to where you are right now.</div></li>
          <li><span>02</span><div><strong>Walk the checkpoints.</strong> Copy as you go. Test as you build.</div></li>
          <li><span>03</span><div><strong>Save the artifact.</strong> It is yours. Iterate forever.</div></li>
        </ol>
      </div>
    </section>

    <section class="path-callout">
      <div class="path-inner">
        <div class="path-intro">
          <p class="eyebrow">LEARNING PATH</p>
          <h2>Skills → Agents → Teams</h2>
          <p>If you're new to Claude Code, these three labs in order teach the orchestration pattern. Start with a skill, turn a role into an agent, then run a team.</p>
        </div>
        <div class="path-steps">
          <a href="/labs/build-your-first-skill" class="path-step">
            <span class="path-num">1</span>
            <div>
              <strong>Build Your First Skill</strong>
              <span>A reusable prompt, in your voice.</span>
            </div>
          </a>
          <span class="path-arrow">→</span>
          <a href="/labs/build-a-custom-agent" class="path-step">
            <span class="path-num">2</span>
            <div>
              <strong>Build a Custom Agent</strong>
              <span>Turn a role you play into a specialist.</span>
            </div>
          </a>
          <span class="path-arrow">→</span>
          <a href="/labs/agent-teams" class="path-step">
            <span class="path-num">3</span>
            <div>
              <strong>Agent Teams</strong>
              <span>Orchestrate specialists on real projects.</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="catalog">
      <div class="catalog-header">
        <p class="eyebrow">LAB CATALOG</p>
        <h2>{labs.length} {labs.length === 1 ? "lab" : "labs"} available</h2>
      </div>

      <div class="lab-grid">
        {labs.map((lab) => (
          <a href={`/labs/${lab.id}`} class="lab-card">
            <div class="lab-card-top">
              <span class="pill" style={difficultyStyles[lab.data.difficulty]}>
                {difficultyLabel[lab.data.difficulty]}
              </span>
              <span class="time">{lab.data.time}</span>
            </div>
            <h3>{lab.data.title}</h3>
            <ul class="learn-bullets">
              {lab.data.learn.slice(0, 3).map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="lab-card-foot">
              <span class="tags">
                {lab.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </span>
              <span class="start">Start lab &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .page {
    color: #0f172a;
  }
  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #5b21b6;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .eyebrow-light { color: #7c3aed; }

  .lab-hero {
    padding: 4rem 0 2.5rem;
    max-width: 760px;
    border-bottom: 1px solid #f1f5f9;
  }
  .lab-hero h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #0f172a;
    margin-bottom: 1rem;
  }
  .lead {
    color: #475569;
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .banner {
    margin: 3rem 0 2rem;
    background: #faf5ff;
    border: 1px solid #e9d5ff;
    border-radius: 1rem;
    padding: 2.5rem 2.75rem;
  }

  .path-callout {
    margin: 0 0 3rem;
    background: linear-gradient(135deg, #f0f9ff 0%, #ffffff 60%);
    border: 1px solid #bae6fd;
    border-radius: 1rem;
    padding: 2rem 2.5rem;
  }
  .path-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .path-intro h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.01em;
    margin: 0.25rem 0 0.5rem;
  }
  .path-intro p {
    color: #475569;
    font-size: 0.98rem;
    line-height: 1.55;
    max-width: 680px;
  }
  .path-steps {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .path-step {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex: 1 1 240px;
    min-width: 220px;
    background: #ffffff;
    border: 1px solid #bae6fd;
    border-radius: 0.75rem;
    padding: 0.9rem 1.1rem;
    text-decoration: none;
    transition: all 0.15s;
  }
  .path-step:hover {
    border-color: #0284c7;
    box-shadow: 0 3px 12px rgba(2, 132, 199, 0.12);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .path-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: #0369a1;
    background: #e0f2fe;
    border: 1px solid #bae6fd;
    width: 1.9rem;
    height: 1.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.4rem;
    flex-shrink: 0;
  }
  .path-step strong {
    display: block;
    color: #0f172a;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 0.15rem;
  }
  .path-step span:not(.path-num) {
    display: block;
    color: #64748b;
    font-size: 0.82rem;
    line-height: 1.4;
  }
  .path-arrow {
    display: flex;
    align-items: center;
    color: #0ea5e9;
    font-weight: 700;
    font-size: 1.2rem;
  }
  @media (max-width: 900px) {
    .path-arrow { display: none; }
  }
  .banner-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .banner h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .banner p {
    color: #475569;
    font-size: 1rem;
    line-height: 1.6;
  }
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .steps li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    color: #475569;
    font-size: 0.95rem;
  }
  .steps span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-weight: 700;
    color: #5b21b6;
    background: #ffffff;
    border: 1px solid #e9d5ff;
    border-radius: 0.5rem;
    padding: 0.4rem 0.65rem;
    flex-shrink: 0;
    line-height: 1;
  }
  .steps strong { color: #0f172a; font-weight: 600; }

  .catalog {
    padding: 1rem 0 5rem;
  }
  .catalog-header {
    margin-bottom: 1.75rem;
  }
  .catalog-header h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.65rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.01em;
  }

  .lab-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 1.25rem;
  }
  .lab-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 0.875rem;
    padding: 1.75rem;
    color: #0f172a;
    transition: all 0.15s;
    text-decoration: none;
  }
  .lab-card:hover {
    border-color: #c4b5fd;
    box-shadow: 0 4px 16px rgba(91, 33, 182, 0.08);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .lab-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }
  .pill {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
    line-height: 1;
  }
  .time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: #6b7280;
  }
  .lab-card h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #0f172a;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .learn-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .learn-bullets li {
    color: #475569;
    font-size: 0.92rem;
    padding-left: 1.1rem;
    position: relative;
    line-height: 1.5;
  }
  .learn-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 5px;
    height: 5px;
    background: #a78bfa;
    border-radius: 50%;
  }
  .lab-card-foot {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid #f1f5f9;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }
  .tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: #6b7280;
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    border-radius: 0.35rem;
    padding: 0.2rem 0.55rem;
  }
  .start {
    font-size: 0.85rem;
    font-weight: 600;
    color: #5b21b6;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .banner-inner { grid-template-columns: 1fr; gap: 2rem; }
    .lab-hero h1 { font-size: 2rem; }
    .lab-grid { grid-template-columns: 1fr; }
  }
</style>
