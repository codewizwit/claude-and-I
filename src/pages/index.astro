---
import Base from "../layouts/Base.astro";
import AgentCard from "../components/AgentCard.astro";
import { getCollection } from "astro:content";

const agents = await getCollection("agents");
const starters = (await getCollection("starters")).sort((a, b) => a.data.order - b.data.order);
const workAgents = agents.filter((a) => a.data.type === "work");
const funAgents = agents.filter((a) => a.data.type === "fun").slice(0, 3);
---

<Base title="Home">
  <div class="topbar">
    <span class="mark">CODE<span class="brand-pop">WIZWIT</span> CLAUDE CODE ENVIRONMENT</span>
  </div>

  <div class="hero">
    <h1>claude <span class="accent">&</span> i<span class="period">.</span></h1>
    <p class="lede">
      A Claude Code environment built to be personalized. Fork it, shape it around how you actually work.
    </p>
    <p class="subtitle">
      Generic tools serve everyone the same way, which means they serve no one particularly well. Build something that serves you specifically. Open source. No Human Left Behind.
    </p>
    <div class="hero-meta">
      <span>{agents.length} Agents</span>
      <span>31 Skills</span>
      <span>{starters.length} Rules</span>
    </div>
    <div class="hero-actions">
      <a href="/agents" class="btn btn-primary">Browse the system</a>
      <a href="/docs/getting-started" class="btn btn-secondary">Fork and customize</a>
    </div>
  </div>

  <section class="section">
    <div class="section-divider">
      <span>THE SYSTEM</span>
      <span>4 / LAYERS</span>
    </div>
    <h2>Four layers that work together</h2>
    <div class="layers-grid">
      <a href="/agents" class="layer-card">
        <span class="card-label">№ 01 / AGENTS</span>
        <span class="layer-num">{agents.length}</span>
        <h3>Agents</h3>
        <p>Specialized assistants for thinking, building, reviewing, and debugging. Each has its own model, tools, and expertise.</p>
      </a>
      <a href="/skills" class="layer-card">
        <span class="card-label">№ 02 / SKILLS</span>
        <span class="layer-num">31</span>
        <h3>Skills</h3>
        <p>Auto-injected knowledge packets that activate based on what you're working on. Setup wizard, CLAUDE.md generator, skill discovery.</p>
      </a>
      <a href="/rules" class="layer-card">
        <span class="card-label">№ 03 / RULES</span>
        <span class="layer-num">{starters.length}</span>
        <h3>Rules</h3>
        <p>Role-based CLAUDE.md files. Pick your role, copy the file, fill in the placeholders. Active every session.</p>
      </a>
      <a href="/docs/settings-json-tips" class="layer-card">
        <span class="card-label">№ 04 / HOOKS</span>
        <span class="layer-num">2</span>
        <h3>Settings / Hooks</h3>
        <p>Permissions, deny rules, automated hooks, and agent teams. Auto-format on save, block push to main, coordinate parallel agents.</p>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="section-divider">
      <span>WORK AGENTS</span>
      <span>{workAgents.length} / SPECIALISTS</span>
    </div>
    <div class="section-header">
      <h2>Different modes of working</h2>
      <a href="/agents" class="see-all">All {agents.length} agents</a>
    </div>
    <div class="agent-grid">
      {workAgents.map((agent) => (
        <AgentCard
          name={agent.data.name}
          type={agent.data.type}
          model={agent.data.model}
          tools={agent.data.tools}
          tagline={agent.data.tagline}
          slug={agent.id}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-divider">
      <span>NOT JUST WORK</span>
      <span>{funAgents.length} / FUN</span>
    </div>
    <h2>Fun agents</h2>
    <p class="section-desc">Philosophy, sci-fi, anime, music. Not everything has to be productive.</p>
    <div class="agent-grid">
      {funAgents.map((agent) => (
        <AgentCard
          name={agent.data.name}
          type={agent.data.type}
          model={agent.data.model}
          tools={agent.data.tools}
          tagline={agent.data.tagline}
          slug={agent.id}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-divider">
      <span>RULES</span>
      <span>{starters.length} / ROLES</span>
    </div>
    <h2>Pick your role</h2>
    <div class="starter-grid">
      {starters.slice(0, 6).map((s) => (
        <a href={`/rules/${s.data.role}`} class="starter-card">
          <h3>{s.data.role.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase())}</h3>
          <p>{s.data.description}</p>
        </a>
      ))}
    </div>
    <a href="/rules" class="see-all" style="display: inline-block; margin-top: 1rem;">All {starters.length} roles</a>
  </section>

  <section class="section philosophy">
    <div class="section-divider">
      <span>WHY PERSONALIZE</span>
      <span>NO HUMAN LEFT BEHIND</span>
    </div>
    <h2>Your environment should work like you do</h2>
    <div class="philosophy-content">
      <p>Most AI setups are one-size-fits-all. Same defaults, same behavior, same blind spots for everyone. That's convenient to ship, but it means the tool never really learns how you think, what you care about, or what you'd never want it to do.</p>
      <p>A personalized environment changes that. When your CLAUDE.md captures how you actually work, when your agents match the problems you actually solve, when your skills inject the patterns you actually use, the gap between what you ask for and what you get shrinks. Dramatically.</p>
      <p>This isn't about configuring for configuration's sake. It's about building something that genuinely serves the person using it. A senior architect and a first-time coder shouldn't get the same experience. A data engineer and a product manager shouldn't get the same guardrails. The specificity is the point.</p>
      <p>We call this <strong>No Human Left Behind</strong>. Technology should adapt to people, not the other way around. Fork this repo, make it yours, and build an environment that actually knows how you work. Then share what you learned so the next person can do the same.</p>
    </div>
  </section>

  <section class="section cta">
    <div class="section-divider">
      <span>MAKE IT YOURS</span>
      <span>3 COMMANDS</span>
    </div>
    <h2>Fork it, run the wizard</h2>
    <p class="section-desc">Fork the repo to own your version, then the setup wizard walks you through picking agents, skills, and a standard.</p>

    <div class="install-toggle">
      <button class="toggle-btn active" data-tab="existing">I have Claude Code</button>
      <button class="toggle-btn" data-tab="fresh">Fresh install</button>
    </div>

    <div class="install-tab active" id="tab-existing">
      <div class="cta-steps">
        <div class="copyable"><code>gh repo fork codewizwit/claude-and-i --clone && cd claude-and-i</code><button class="copy-btn" aria-label="Copy">Copy</button></div>
        <div class="copyable"><code>claude</code><button class="copy-btn" aria-label="Copy">Copy</button></div>
        <div class="copyable"><code>/setup</code><button class="copy-btn" aria-label="Copy">Copy</button></div>
      </div>
      <p class="cta-note">Three commands. The wizard picks your role, agents, and skills, then copies everything to <code>~/.claude/</code>.</p>
    </div>

    <div class="install-tab" id="tab-fresh">
      <div class="cta-steps">
        <div class="copyable"><code>npm install -g @anthropic-ai/claude-code</code><button class="copy-btn" aria-label="Copy">Copy</button></div>
        <div class="copyable"><code>gh repo fork codewizwit/claude-and-i --clone && cd claude-and-i</code><button class="copy-btn" aria-label="Copy">Copy</button></div>
        <div class="copyable"><code>claude</code><button class="copy-btn" aria-label="Copy">Copy</button></div>
        <div class="copyable"><code>/setup</code><button class="copy-btn" aria-label="Copy">Copy</button></div>
      </div>
      <p class="cta-note">Install Claude Code first, then fork and run the wizard. Need Node.js too? <a href="/docs/getting-started">See the full guide</a>.</p>
    </div>
  </section>

  <script>
    document.querySelectorAll('.toggle-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.install-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab)?.classList.add('active');
      });
    });
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const code = btn.previousElementSibling?.textContent || '';
        navigator.clipboard.writeText(code);
        btn.textContent = 'Copied';
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      });
    });
  </script>
</Base>

<style>
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    padding: 0.5rem 0 clamp(2rem, 6vh, 4rem);
  }
  .topbar .mark { color: var(--text); font-weight: 600; }
  .topbar .brand-pop {
    color: var(--accent-dark);
    font-weight: 700;
  }

  .section-divider {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
  }
  .section-divider span:first-child { color: var(--text); font-weight: 600; }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-bottom: 0.4rem;
  }

  .hero {
    padding: 0 0 clamp(2rem, 6vh, 4rem);
    max-width: 100%;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3.5rem, 12vw, 9rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
    margin: 0;
    color: var(--text);
    text-wrap: balance;
  }
  .hero h1 .accent {
    font-family: var(--font-body);
    color: var(--accent-dark);
    font-style: italic;
    font-weight: 500;
    font-variation-settings: normal;
    padding: 0 0.05em;
  }
  .hero h1 .period { color: var(--text); }
  .lede {
    margin-top: clamp(1.5rem, 3vh, 2rem);
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(1.125rem, 1.6vw, 1.4rem);
    line-height: 1.45;
    color: var(--text-muted);
    max-width: 38rem;
  }
  .subtitle {
    color: var(--text-muted);
    font-size: 1rem;
    margin-top: 1.25rem;
    line-height: 1.65;
    max-width: 42rem;
  }
  .hero-meta {
    margin-top: 2rem;
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
  }
  .hero-meta span { color: var(--text); }
  .hero-actions {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
  }
  .btn {
    padding: 0.6rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 500;
    font-size: 0.9rem;
    transition: opacity 0.15s;
  }
  .btn:hover { opacity: 0.9; text-decoration: none; }
  .btn-primary { background: var(--accent-dim); color: white; }
  .btn-secondary { border: 1px solid var(--border); color: var(--text); }

  .section { padding: 2.5rem 0; }
  .section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    font-family: var(--font-display);
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 0.5rem;
  }
  .section-desc {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .see-all { font-size: 0.9rem; color: var(--text-muted); }

  .layers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 1rem;
  }
  .layer-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.75rem 1.5rem 1.5rem;
    color: var(--text);
    transition: border-color 0.2s var(--ease-out), transform 0.2s var(--ease-out);
    display: block;
    position: relative;
    overflow: hidden;
  }
  .layer-card:hover {
    border-color: var(--accent);
    text-decoration: none;
    transform: translateY(-2px);
  }
  .card-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .layer-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(3.5rem, 5vw, 4.5rem);
    line-height: 0.9;
    color: var(--accent-dark);
    font-variation-settings: "opsz" 144, "SOFT" 100;
    display: block;
    margin-bottom: 0.75rem;
  }
  .layer-card h3 {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
    color: var(--text);
  }
  .layer-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .agent-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .starter-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }
  .starter-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    color: var(--text);
    transition: border-color 0.15s;
  }
  .starter-card:hover { border-color: var(--accent-dim); text-decoration: none; }
  .starter-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.3rem; }
  .starter-card p { font-size: 0.85rem; color: var(--text-muted); }

  .install-toggle {
    display: flex;
    gap: 0;
    margin-top: 1.75rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
    width: fit-content;
  }
  .toggle-btn {
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
    font-family: inherit;
    background: transparent;
    color: var(--text-muted);
    border: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .toggle-btn:hover { color: var(--text); }
  .toggle-btn.active {
    background: var(--bg-card);
    color: var(--text);
  }
  .install-tab { display: none; }
  .install-tab.active { display: block; }

  .philosophy-content {
    max-width: 640px;
    margin-top: 1rem;
  }
  .philosophy-content p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .philosophy-content p:last-child {
    margin-bottom: 0;
  }
  .philosophy-content strong {
    color: var(--text);
  }

  .cta { padding: 3rem 0 4rem; }
  .cta-steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 650px;
  }
  .copyable {
    display: flex;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .copyable code {
    flex: 1;
    padding: 0.6rem 1rem;
    font-size: 0.85rem;
    display: block;
    overflow-x: auto;
    white-space: nowrap;
    background: none;
    border: none;
  }
  .copy-btn {
    padding: 0.6rem 1rem;
    font-size: 0.75rem;
    font-family: inherit;
    background: transparent;
    color: var(--text-muted);
    border: none;
    border-left: 1px solid var(--border);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .copy-btn:hover { color: var(--text); }
  .cta-note {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 1.25rem;
    max-width: 550px;
  }
  .cta-note code {
    display: inline;
    border: none;
    padding: 0.1rem 0.35rem;
    font-size: 0.85em;
  }

  @media (max-width: 768px) {
    .layers-grid, .agent-grid, .starter-grid { grid-template-columns: 1fr; }
    .hero h1 { font-size: 1.8rem; }
    .section-header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>
